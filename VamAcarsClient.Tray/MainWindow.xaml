<Window x:Class="VamAcarsClient.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:VamAcarsClient.Tray.Models"
        mc:Ignorable="d"
        Title="VAM ACARS Client"
        Width="480"
        Height="960"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#1c1c23"
        Foreground="#e8e8ee"
        FontFamily="Segoe UI"
        d:DataContext="{d:DesignInstance Type=models:AcarsClientState}">

    <!--
        Theme matches the vam.kevindrack.de dashboard's dark palette.
        Colours pulled from the live-app:
          Bg primary:    #1c1c23
          Bg secondary:  #25252e
          Border:        #34343f
          Text primary:  #e8e8ee
          Text muted:    #9090a0
          Accent (blue): #78c8ff
          Accent (green):#5dd594
          Accent (red):  #ff7a87
        These live as static resources so the next theme-pass can swap
        them in one place instead of grepping through the XAML.
    -->
    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1c1c23" />
        <SolidColorBrush x:Key="BgSecondary" Color="#25252e" />
        <SolidColorBrush x:Key="BorderMuted" Color="#34343f" />
        <SolidColorBrush x:Key="TextPrimary" Color="#e8e8ee" />
        <SolidColorBrush x:Key="TextMuted" Color="#9090a0" />
        <SolidColorBrush x:Key="AccentBlue" Color="#78c8ff" />
        <SolidColorBrush x:Key="AccentGreen" Color="#5dd594" />
        <SolidColorBrush x:Key="AccentRed" Color="#ff7a87" />
        <SolidColorBrush x:Key="AccentYellow" Color="#f5c451" />

        <!--
            Bool → Visibility for the conditional update notice in
            EINSTELLUNGEN. WPF has a built-in BooleanToVisibilityConverter
            in System.Windows.Controls that maps true → Visible and
            false → Collapsed (NOT Hidden — Collapsed removes from
            layout). Declared once here, referenced by key below.
        -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--
            "Card": grouped section with rounded border and inner padding.
            We don't use a UserControl for this because the variance is
            small and inlining keeps the XAML readable as a single doc.
        -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgSecondary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>

        <!--
            CheckBox style for the preferences card. WPF's default
            checkbox renders the indicator with system-aero greys
            that clash with the dark theme; we restyle minimally
            (Foreground, indicator brushes) without re-templating
            so we keep native focus/disabled states. Margin gives
            the label a tiny bit of breathing room from the box.
        -->
        <Style x:Key="PrefCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource BgPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!--
            Form-input style for the callsign / dep / arr boxes. Dark
            theme, monospaced font (so ICAO codes line up visually),
            disables itself while a session is running so the user
            can't edit mid-flight. Triggers on ConnectionStatus =
            Connected / Connecting — both states mean "leave the form
            alone". Disconnected and Error allow editing.
        -->
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgPrimary}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBlue}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBlue}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connected">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.55" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connecting">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.55" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--
            Connect/Disconnect button. Three visual states driven by
            ConnectionStatus DataTriggers:
              Disconnected / Error → Green, label "Verbinden"
              Connecting           → Yellow, label "Verbinde…", disabled
              Connected            → Red, label "Trennen"
            Single button toggles the action — Click handler in code-
            behind reads State.ConnectionStatus to decide Start vs Stop.
            Cursor=Hand because users expect that on actionable buttons.
        -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}" />
            <Setter Property="Foreground" Value="{StaticResource BgPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Content" Value="Verbinden" />
            <Setter Property="Template">
                <!--
                    Default WPF button has rounded-only-on-some-themes and
                    pulls a system-coloured 'pressed' state. Replacing the
                    template with a flat Border keeps our colours intact
                    across Windows themes. ContentPresenter handles the
                    label centring; no inner padding needed beyond the
                    Border padding.
                -->
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connected">
                    <Setter Property="Background" Value="{StaticResource AccentRed}" />
                    <Setter Property="Content" Value="Trennen" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connecting">
                    <Setter Property="Background" Value="{StaticResource AccentYellow}" />
                    <Setter Property="Content" Value="Verbinde…" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <!--
                    Pre-flight gate (option #10). Disable Verbinden when
                    the checklist is incomplete AND we're in a
                    pre-connection state (Disconnected or Error). We
                    don't gate Connected — the button at that point is
                    "Trennen", and we want the user to always be able
                    to disconnect regardless of checklist state. Two
                    MultiDataTriggers (one per pre-connection state)
                    rather than collapsing into a single trigger because
                    WPF MultiDataTrigger requires all conditions to be
                    equal-value matches; there's no native OR operator.
                -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding PreflightComplete}" Value="False" />
                        <Condition Binding="{Binding ConnectionStatus}" Value="Disconnected" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.5" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding PreflightComplete}" Value="False" />
                        <Condition Binding="{Binding ConnectionStatus}" Value="Error" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.5" />
                </MultiDataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- Content (scrollable) -->
            <RowDefinition Height="Auto" /> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ─── HEADER ─────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="VAM ACARS Client"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}" />

            <!--
                Status pill: fills with a colour that depends on the
                ConnectionStatus enum value. We use DataTriggers on the
                Border's background to map enum values to brushes —
                lighter than introducing an IValueConverter for a
                4-state enum that won't change shape.
            -->
            <Border CornerRadius="12"
                    Padding="10,4"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource TextMuted}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connected">
                                <Setter Property="Background" Value="{StaticResource AccentGreen}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connecting">
                                <Setter Property="Background" Value="{StaticResource AccentYellow}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ConnectionStatus}" Value="Error">
                                <Setter Property="Background" Value="{StaticResource AccentRed}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ConnectionStatus}"
                           Foreground="{StaticResource BgPrimary}"
                           FontSize="11"
                           FontWeight="Bold" />
            </Border>

            <!--
                A2 — Secondary network-pill. Mirrors NetworkHealthState
                ("Online"/"Degraded"/"Offline") with the same color
                bucketing as the HEARTBEATS expander, but at glance-
                distance in the header so the pilot doesn't need to
                unfold the expander mid-flight to know if heartbeats
                are landing.

                Visibility gated on ConnectionStatus=Connected — before
                Verbinden there's nothing meaningful to report, showing
                "● NETZ: Unknown" while the form is being filled would
                be visual noise. After Trennen the pill disappears
                again. Slightly smaller than the ConnectionStatus pill
                so the visual hierarchy stays honest: "Connected" is
                the primary state, "Online/Degraded/Offline" is the
                secondary detail.
            -->
            <Border CornerRadius="10"
                    Padding="8,3"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Background" Value="{StaticResource TextMuted}" />
                        <Style.Triggers>
                            <!--
                                Order matters: the connect-gate trigger
                                comes first so the visibility flip wins
                                over the default Collapsed setter. The
                                three NetworkHealthState triggers then
                                paint the background — none of them
                                touch Visibility, so the Connected gate
                                stays in effect.
                            -->
                            <DataTrigger Binding="{Binding ConnectionStatus}" Value="Connected">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NetworkHealthState}" Value="Online">
                                <Setter Property="Background" Value="{StaticResource AccentGreen}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NetworkHealthState}" Value="Degraded">
                                <Setter Property="Background" Value="{StaticResource AccentYellow}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NetworkHealthState}" Value="Offline">
                                <Setter Property="Background" Value="{StaticResource AccentRed}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="● NETZ: "
                               Foreground="{StaticResource BgPrimary}"
                               FontSize="10"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding NetworkHealthState}"
                               Foreground="{StaticResource BgPrimary}"
                               FontSize="10"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ─── CONTENT ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--
                    A2 — Recovery-flash banner. Visible for 5 seconds
                    after the network transitions from Offline back to
                    Online, then auto-hides via the one-shot
                    DispatcherTimer in AcarsClientService.

                    Why a transient banner rather than just relying on
                    the secondary network-pill color flip: pilots may
                    be busy in the cockpit and miss the moment the
                    pill turns from red to green. A short-lived banner
                    catches the eye while still respecting screen
                    real-estate by disappearing once the recovery is
                    no longer news.

                    AccentGreen border + tint signals "good news"
                    (contrast with the AccentYellow recovery-session
                    banner below, which signals "attention needed").
                    Margin matches the recovery-session banner so when
                    both happen to be visible at the same time (rare
                    but possible — crashed session AND just-recovered
                    network) they read as a stacked notification
                    column rather than collapsing into each other.
                -->
                <Border CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="{StaticResource AccentGreen}"
                        Background="{StaticResource BgSecondary}"
                        Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="{Binding NetworkRecoveredFlash, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="✓  Verbindung wiederhergestellt"
                               Foreground="{StaticResource AccentGreen}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>

                <!--
                    Recovery banner (option #13). Visible only when
                    State.HasRecoverableSession=true — i.e. when the
                    previous session ended without a clean Stop and the
                    SessionMarker file is still on disk. The banner
                    lets the pilot pick up where they left off
                    (Wiederverbinden, which pre-fills the form fields
                    from the marker) or dismiss the recovery
                    (Verwerfen, which deletes the marker so the banner
                    doesn't re-appear next launch).

                    AccentYellow border + tinted background so it
                    visually flags as "needs your attention" without
                    looking like an error (which would be red). Sits
                    at the very top of the ScrollViewer so it's the
                    first thing the user sees on opening the window
                    after a crash — and it disappears entirely
                    (Visibility=Collapsed via BoolToVis) on normal
                    startups so it doesn't take up vertical space.
                -->
                <Border CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="{StaticResource AccentYellow}"
                        Background="{StaticResource BgSecondary}"
                        Padding="16"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasRecoverableSession, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="LETZTE SITZUNG"
                                   Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource AccentYellow}" />

                        <TextBlock Text="{Binding RecoverableSessionSummary, FallbackValue='—', TargetNullValue='—'}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="Die letzte Sitzung wurde nicht sauber beendet. Wiederverbinden füllt die Form-Felder vor; Verwerfen löscht den Wiederherstellungs-Marker."
                                   Margin="0,6,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap" />

                        <!--
                            Two-button row. Resume is the AccentBlue
                            primary action; Verwerfen is subdued
                            BgSecondary with a border, matching the
                            pattern from "Auf Updates prüfen" + the
                            re-pair button. Buttons sit side-by-side
                            in a horizontal StackPanel.
                        -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="ResumeSessionButton"
                                    Click="OnResumeSessionClick"
                                    Padding="14,6"
                                    Background="{StaticResource AccentBlue}"
                                    Foreground="{StaticResource BgPrimary}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Content="Wiederverbinden"
                                    ToolTip="Übernimmt Callsign + Departure + Arrival aus der unterbrochenen Sitzung in die FLUG-KONTEXT-Felder. Du klickst danach selbst Verbinden.">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="DiscardSessionButton"
                                    Click="OnDiscardSessionClick"
                                    Margin="8,0,0,0"
                                    Padding="14,6"
                                    Background="{StaticResource BgSecondary}"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="12"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderMuted}"
                                    Cursor="Hand"
                                    Content="Verwerfen"
                                    ToolTip="Löscht den Wiederherstellungs-Marker. Das Banner erscheint nicht mehr — die unterbrochene Sitzung wird verworfen.">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgPrimary}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Connection card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="VERBINDUNG" Style="{StaticResource SectionLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Server" Style="{StaticResource FieldLabel}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding ServerUrl}" Style="{StaticResource FieldValue}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0"
                                       Text="Token" Style="{StaticResource FieldLabel}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                                <!--
                                    Style is set via property-element here
                                    (instead of attribute) so we can attach
                                    DataTriggers. BasedOn pulls in the
                                    base FieldValue setters; the triggers
                                    override Text + Foreground when
                                    HasToken flips. Setting Style="..." as
                                    an attribute AND defining inline at
                                    the same time is a hard XAML error.
                                -->
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource FieldValue}">
                                        <Setter Property="Text" Value="✗  Nicht gepaart" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentYellow}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasToken}" Value="True">
                                                <Setter Property="Text" Value="✓  Gepaart" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreen}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!--
                            Pairing-button (in-app device-pairing). Visible
                            only when HasToken=False — once the user is
                            paired the button disappears entirely (no
                            layout gap), and the "Gerät neu koppeln"-
                            button further down handles the inverse
                            (visible only when HasToken=True). Together
                            the two buttons cover both directions of the
                            pairing lifecycle without ever showing both
                            at once.

                            AccentBlue fill matches the install-update
                            button — both are "primary action when
                            visible" affordances. Click handler in code-
                            behind opens PairingDialog as a modal owned
                            by this window so it gets the right z-order
                            and sits centred over MainWindow.
                        -->
                        <Button x:Name="PairButton"
                                Click="OnPairClick"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0"
                                Padding="14,6"
                                Background="{StaticResource AccentBlue}"
                                Foreground="{StaticResource BgPrimary}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Content="Gerät pairen…"
                                ToolTip="Öffnet einen Dialog, in dem du den 9-stelligen Pairing-Code aus vam.kevindrack.de/settings eingibst.">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <!--
                                        Default Collapsed (so paired-state
                                        users never see the button), flipped
                                        to Visible when HasToken=False. We
                                        invert the trigger relative to the
                                        existing "Gerät neu koppeln" button
                                        further down, which uses the BoolToVis
                                        converter directly (HasToken=true
                                        → visible). No need for an inverted
                                        converter — DataTrigger handles the
                                        polarity flip cleanly.
                                    -->
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasToken}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!--
                    Flight context card. Top half: editable form
                    (Callsign, Network, Departure ICAO, Arrival ICAO).
                    Bottom half: live readouts (Aircraft, Phase) that
                    populate from heartbeat responses once connected.
                    Form fields auto-disable while running via the
                    FormTextBox style's DataTriggers — no manual
                    IsEnabled toggling in code-behind needed.
                -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="FLUG-KONTEXT" Style="{StaticResource SectionLabel}" />

                        <!-- Editable form -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Callsign" Style="{StaticResource FieldLabel}" />
                            <TextBox  Grid.Row="0" Grid.Column="1"
                                      x:Name="CallsignBox"
                                      Text="NGN901"
                                      Style="{StaticResource FormTextBox}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0"
                                       Text="Network" Style="{StaticResource FieldLabel}" />
                            <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"
                                      x:Name="NetworkBox"
                                      Text="Offline"
                                      Style="{StaticResource FormTextBox}"
                                      ToolTip="Offline | VATSIM | IVAO" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0"
                                       Text="Departure" Style="{StaticResource FieldLabel}" />
                            <TextBox  Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"
                                      x:Name="DeparturBox"
                                      Text="EDDF"
                                      MaxLength="4"
                                      Style="{StaticResource FormTextBox}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0"
                                       Text="Arrival" Style="{StaticResource FieldLabel}" />
                            <TextBox  Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                                      x:Name="ArrivalBox"
                                      Text="EDDM"
                                      MaxLength="4"
                                      Style="{StaticResource FormTextBox}" />
                        </Grid>

                        <!-- Live readouts (populated from heartbeats) -->
                        <Border BorderBrush="{StaticResource BorderMuted}"
                                BorderThickness="0,1,0,0"
                                Margin="0,16,0,0"
                                Padding="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Aircraft" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding AircraftType, FallbackValue='—', TargetNullValue='—'}"
                                           Style="{StaticResource FieldValue}" />

                                <!--
                                    Registration row (M3.8.1). Echoed verbatim
                                    by the server alongside the resolved
                                    aircraftType so we show "A320 + D-ANNE"
                                    matching the live-map. Null falls back to
                                    em-dash for pilots flying without a set
                                    tail number.
                                -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0"
                                           Text="Registration" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"
                                           Text="{Binding AircraftRegistration, FallbackValue='—', TargetNullValue='—'}"
                                           Style="{StaticResource FieldValue}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0"
                                           Text="Phase" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0"
                                           Text="{Binding PhaseDisplay, FallbackValue='—', TargetNullValue='—'}"
                                           Style="{StaticResource FieldValue}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!--
                    OFP-Import card (option #12). Lets the pilot paste
                    a SimBrief / FlightAware / PFPX OFP text dump and
                    have its key fields (callsign, departure, arrival,
                    cruise altitude) auto-filled into FLUG-KONTEXT. The
                    parser is a heuristic regex battery — see
                    VamAcarsClient.Core.OfpParser for the supported
                    patterns.

                    Layout: section label + multi-line monospaced text
                    box + hint text + import button. The text box uses
                    BgPrimary so it visually matches the form-input
                    style of the FLUG-KONTEXT TextBoxes one card up;
                    multi-line + AcceptsReturn so users can paste an
                    entire OFP block, not just one line. MinHeight=90
                    gives the box room without dominating the window.

                    Why a separate card rather than collapsing into
                    FLUG-KONTEXT: the import workflow is conceptually
                    distinct from the flight-context form — paste-and-
                    parse on one side, type-and-edit on the other. A
                    dedicated card keeps the visual hierarchy honest.
                -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="OFP-IMPORT" Style="{StaticResource SectionLabel}" />

                        <TextBox x:Name="OfpInputBox"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="90"
                                 MaxHeight="180"
                                 Background="{StaticResource BgPrimary}"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderMuted}"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 CaretBrush="{StaticResource AccentBlue}"
                                 SelectionBrush="{StaticResource AccentBlue}" />

                        <TextBlock Margin="0,8,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Text="Füge OFP-text aus SimBrief / FlightAware / PFPX ein und klicke 'Importieren'. Erkannte Felder werden in FLUG-KONTEXT übernommen." />

                        <Button x:Name="OfpImportButton"
                                Click="OnOfpImportClick"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Padding="14,6"
                                Background="{StaticResource BgSecondary}"
                                Foreground="{StaticResource TextPrimary}"
                                FontSize="12"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderMuted}"
                                Cursor="Hand"
                                Content="Importieren"
                                ToolTip="Liest Callsign + Dep/Arr ICAO + Cruise-Altitude aus dem oben eingefügten OFP-Text und füllt die FLUG-KONTEXT-Felder vor.">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BgPrimary}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!--
                    Pre-flight checklist card (option #10). Discipline-
                    tool + connect-gate. The user ticks each item before
                    clicking Verbinden; the PrimaryButton's
                    MultiDataTrigger blocks the button while the
                    checklist is incomplete and the connection state is
                    Disconnected/Error.

                    ItemsControl renders the ObservableCollection from
                    the State. Each row is a CheckBox with TwoWay binding
                    on IsChecked — toggling it fires the item's
                    PropertyChanged, which the State forwards as a
                    PreflightComplete change, which re-evaluates the
                    Connect button's IsEnabled trigger. No code-behind
                    needed for the ticking itself.

                    Per-session reset happens in
                    AcarsClientService.StopAsync — see ResetPreflight-
                    Checklist's docstring for rationale.
                -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="PRE-FLIGHT" Style="{StaticResource SectionLabel}" />
                        <ItemsControl ItemsSource="{Binding PreflightChecklist}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PreflightChecklistItem}">
                                    <!--
                                        TwoWay binding so user clicks
                                        flow into the POCO's IsChecked
                                        setter, which fires the
                                        PropertyChanged that bubbles up.
                                        Margin gives breathing room
                                        between rows; PrefCheckBox style
                                        matches the EINSTELLUNGEN look.
                                    -->
                                    <CheckBox Content="{Binding Label}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              Style="{StaticResource PrefCheckBox}"
                                              Margin="0,4,0,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--
                            Status-hint shown when the user hasn't
                            ticked everything yet. The hint references
                            the gate so a confused user can find the
                            cause of the disabled Verbinden button
                            without reading the source. Hidden once
                            PreflightComplete=true so it doesn't shout
                            redundantly when the gate is open.
                        -->
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource AccentYellow}"
                                   TextWrapping="Wrap"
                                   Text="Alle Punkte abhaken um Verbinden freizuschalten.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreflightComplete}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!--
                            Sim-probe sub-section (option #11). Reads
                            the currently loaded aircraft from MSFS via
                            a one-shot SimConnect query, without starting
                            the heartbeat session. Lets the pilot verify
                            "yes, MSFS has my A320 loaded" before pressing
                            Verbinden — closes a real gap where wrong-
                            aircraft mismatches only became visible after
                            heartbeats started flowing.

                            Layout: separator + button + 2 read-only rows
                            (Aircraft / Registration). Display rows mirror
                            the FLUG-KONTEXT readouts visually but bind
                            to DetectedAircraft* (raw SimConnect) rather
                            than AircraftType / Registration (server-
                            resolved). Empty/null values fall back to
                            em-dash via TargetNullValue.
                        -->
                        <Border BorderBrush="{StaticResource BorderMuted}"
                                BorderThickness="0,1,0,0"
                                Margin="0,12,0,0"
                                Padding="0,12,0,0">
                            <StackPanel>
                                <Button x:Name="ProbeSimButton"
                                        Click="OnProbeSimClick"
                                        HorizontalAlignment="Left"
                                        Padding="14,6"
                                        Background="{StaticResource BgSecondary}"
                                        Foreground="{StaticResource TextPrimary}"
                                        FontSize="12"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource BorderMuted}"
                                        Cursor="Hand"
                                        ToolTip="Liest Flugzeugtyp + Registration aus MSFS via SimConnect (ohne Heartbeats zu starten).">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <!--
                                                    Disable while a probe is in
                                                    flight to prevent stacking
                                                    concurrent SimConnect
                                                    handshakes. The label flip
                                                    lives on the inner TextBlock
                                                    (same pattern as the
                                                    "Auf Updates prüfen" button).
                                                -->
                                                <DataTrigger Binding="{Binding IsProbingSim}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Setter Property="Opacity" Value="0.7" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BgPrimary}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Sim erkennen" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsProbingSim}" Value="True">
                                                        <Setter Property="Text" Value="Erkenne…" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>

                                <!--
                                    Detected-aircraft display rows.
                                    Mirrors the FLUG-KONTEXT readout
                                    layout (label left, value right,
                                    em-dash on null) so users get a
                                    consistent visual rhythm when their
                                    eye scans both cards.
                                -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Erkanntes Flugzeug" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding DetectedAircraftType, FallbackValue='—', TargetNullValue='—'}"
                                               Style="{StaticResource FieldValue}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0"
                                               Text="Registration" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"
                                               Text="{Binding DetectedAircraftRegistration, FallbackValue='—', TargetNullValue='—'}"
                                               Style="{StaticResource FieldValue}" />

                                    <!--
                                        Simulator row (option #14). Shows the canonical
                                        sim-name ("MSFS 2020", "MSFS 2024", "FSX", "Prepar3D",
                                        or raw szApplicationName for unknown sims) so the
                                        pilot sees which flight simulator the probe just
                                        connected to. Bound to State.DetectedSimulator
                                        which is populated by App.ProbeSimAsync from the
                                        SimConnect handshake's szApplicationName via
                                        AcarsClientState.MapSimulatorName.
                                    -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0"
                                               Text="Simulator" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0"
                                               Text="{Binding DetectedSimulator, FallbackValue='—', TargetNullValue='—'}"
                                               Style="{StaticResource FieldValue}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!--
                    Connect/Disconnect button. Style handles the colour
                    + label flip via ConnectionStatus triggers; click
                    handler in code-behind decides Start vs Stop based
                    on the same state. Stretched horizontally so it
                    reads as the primary action of the window.

                    Option #10: IsEnabled is gated on PreflightComplete
                    when Disconnected/Error. The MultiDataTrigger inside
                    PrimaryButton's Style handles this — we don't need
                    a per-instance binding here.
                -->
                <Button x:Name="ConnectButton"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,12"
                        Click="OnConnectClick" />

                <!-- Heartbeat counters card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="HEARTBEATS" Style="{StaticResource SectionLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center"
                                       Text="{Binding HeartbeatsSent}"
                                       Foreground="{StaticResource AccentGreen}"
                                       FontFamily="Consolas" FontSize="20" FontWeight="Bold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center"
                                       Text="{Binding HeartbeatsFailed}"
                                       Foreground="{StaticResource AccentRed}"
                                       FontFamily="Consolas" FontSize="20" FontWeight="Bold" />
                            <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center"
                                       Text="{Binding HeartbeatsQueued}"
                                       Foreground="{StaticResource AccentYellow}"
                                       FontFamily="Consolas" FontSize="20" FontWeight="Bold" />

                            <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center"
                                       Text="sent" Style="{StaticResource FieldLabel}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center"
                                       Text="failed" Style="{StaticResource FieldLabel}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center"
                                       Text="queued" Style="{StaticResource FieldLabel}" />
                        </Grid>

                        <!--
                            Telemetrie-tab (Welle A — option A1). Progressive
                            disclosure via Expander: collapsed by default so
                            the card stays compact for pilots who just want
                            the three big numbers (sent/failed/queued), but
                            one click away when troubleshooting connection
                            quality.

                            Bindings refresh on AcarsClientService's 2s
                            DispatcherTimer tick. NetworkHealthState is the
                            most actionable signal — color-coded via DataTrigger
                            so a glance tells the pilot if the link is healthy:
                            green=Online (under 30s ago + ≤10% failure),
                            yellow=Degraded, red=Offline, muted=Unknown.

                            All four lines bind directly to AcarsClientState
                            properties; no converters in the chain so the UI
                            re-renders the moment the timer writes the new
                            value via PropertyChanged.
                        -->
                        <Expander Margin="0,12,0,0"
                                  Header="Details anzeigen"
                                  Foreground="{StaticResource TextMuted}"
                                  FontSize="11"
                                  IsExpanded="False">
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Letzte Latenz"
                                           Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding LastLatencyMs, StringFormat={}{0} ms}"
                                           Style="{StaticResource FieldValue}" Margin="0,0,0,4" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Ø Latenz (5min)"
                                           Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding AverageLatencyMs5Min, StringFormat={}{0} ms}"
                                           Style="{StaticResource FieldValue}" Margin="0,0,0,4" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Fehlerrate (5min)"
                                           Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding FailureRatePercent5Min, StringFormat={}{0}%}"
                                           Style="{StaticResource FieldValue}" Margin="0,0,0,4" />

                                <!--
                                    A2: "Letzter Versuch" — seconds since the
                                    most recent heartbeat outcome. Helps the
                                    pilot tell the difference between "loop
                                    is alive but failing fast" (small value)
                                    and "loop is stuck" (growing without
                                    bound). 0 displays as "0 s" right after
                                    connect; once the first heartbeat lands
                                    it cycles between 0-2 s under normal
                                    conditions.
                                -->
                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="Letzter Versuch"
                                           Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{Binding TimeSinceLastOutcomeSec, StringFormat={}{0} s}"
                                           Style="{StaticResource FieldValue}" Margin="0,0,0,4" />

                                <TextBlock Grid.Row="4" Grid.Column="0"
                                           Text="Netzwerk"
                                           Style="{StaticResource FieldLabel}" />
                                <!--
                                    NetworkHealthState colored via DataTrigger.
                                    Style override on TextBlock (not the
                                    shared FieldValue) because we need a
                                    Style.Triggers block — applying triggers
                                    via Style.Triggers on FieldValue would
                                    leak the color logic to every other
                                    FieldValue in the window. The base
                                    properties (font, alignment) mirror
                                    FieldValue manually.
                                -->
                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Text="{Binding NetworkHealthState}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontFamily="Consolas">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NetworkHealthState}" Value="Online">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NetworkHealthState}" Value="Degraded">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentYellow}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NetworkHealthState}" Value="Offline">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentRed}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Expander>
                    </StackPanel>
                </Border>

                <!--
                    Preferences card (M4 Phase 3). Currently exposes
                    just the auto-start-with-Windows toggle, but kept
                    as a generic "Einstellungen" container so future
                    user-prefs (notification opt-in, sim path
                    overrides, etc.) drop in without re-architecting.

                    The checkbox uses OneWay binding to the View-
                    Model so external changes (registry edited by
                    hand, SetAutoStart's failure-path re-sync)
                    refresh the visual, but the user's click is the
                    only path that mutates the registry — handled
                    explicitly in code-behind via OnAutoStartClick.
                    TwoWay would have leaked registry IO into the
                    binding setter and made the success/failure
                    handling harder to reason about.
                -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="EINSTELLUNGEN" Style="{StaticResource SectionLabel}" />
                        <CheckBox x:Name="AutoStartCheck"
                                  Content="Mit Windows starten"
                                  Style="{StaticResource PrefCheckBox}"
                                  IsChecked="{Binding AutoStartEnabled, Mode=OneWay}"
                                  Click="OnAutoStartClick"
                                  ToolTip="Startet den VAM ACARS Client automatisch beim Windows-Login (HKCU\…\Run, kein Admin nötig)." />

                        <!--
                            Audio cue toggle (option #5). OneWay binding +
                            explicit click handler — same pattern as
                            AutoStartCheck above; the click handler routes
                            through App.SetAudioCueEnabled which persists
                            the choice via PreferencesStore. Default off
                            on a fresh install (silent until pilot opts in).
                        -->
                        <CheckBox x:Name="AudioCueCheck"
                                  Content="Audio-Cue bei Phasenwechsel"
                                  Style="{StaticResource PrefCheckBox}"
                                  IsChecked="{Binding AudioCueEnabled, Mode=OneWay}"
                                  Click="OnAudioCueClick"
                                  ToolTip="Spielt einen Windows-Systemton bei Pushback, Takeoff und Touchdown." />

                        <!--
                            Version + update controls (M5). Layout:
                            permanent "Version: x.y.z" line, then a
                            conditional block (Visibility bound to
                            UpdateAvailable) showing the new version
                            and an "Installieren" button. Button is
                            gated on UpdateDownloaded so the user
                            can't apply mid-download — once download
                            completes it goes live.

                            The version label uses Consolas to match
                            the FieldValue style elsewhere; "Version:"
                            label uses FieldLabel for visual parity.
                        -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Version" Style="{StaticResource FieldLabel}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding InstalledVersion, FallbackValue='dev'}"
                                       Style="{StaticResource FieldValue}" />
                        </Grid>

                        <!--
                            Update-available block. Visibility is bound to
                            State.UpdateAvailable via BoolToVis converter,
                            so the whole block disappears (Collapsed)
                            when there's nothing to install. The download
                            phase is differentiated by a small text below
                            the version line: "Wird heruntergeladen…"
                            until UpdateDownloaded flips, then the
                            button becomes clickable.
                        -->
                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                            <TextBlock Foreground="{StaticResource AccentBlue}" FontSize="12">
                                <Run Text="Update verfügbar: " />
                                <Run Text="{Binding LatestVersion, FallbackValue='?', Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                            <!--
                                "Wird heruntergeladen…" placeholder when
                                update is detected but nupkg not yet on
                                disk. Hides itself once UpdateDownloaded
                                flips so we don't show "downloading…"
                                next to a clickable Install button.
                            -->
                            <TextBlock Text="Wird heruntergeladen…"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"
                                       Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateDownloaded}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!--
                                Install button. Smaller than the primary
                                Connect button; we inline the styling to
                                avoid bloating Window.Resources for a
                                single use. Disabled until the download
                                finishes (UpdateDownloaded=true).
                            -->
                            <Button x:Name="ApplyUpdateButton"
                                    Content="Update installieren"
                                    Click="OnApplyUpdateClick"
                                    IsEnabled="{Binding UpdateDownloaded}"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0"
                                    Padding="14,6"
                                    Background="{StaticResource AccentBlue}"
                                    Foreground="{StaticResource BgPrimary}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!--
                            Manual update-check button (M5 Phase 2).
                            Visible when no update is currently known —
                            mutually exclusive with the conditional
                            block above. Lets the user re-trigger a
                            check without restarting the app, useful
                            after a known release ships ("did 0.2.0
                            land yet?") or as a recovery affordance
                            if the startup-check failed silently
                            (network blip, GitHub rate limit, etc.).

                            Visibility logic via DataTrigger (default
                            Visible, flip Collapsed when UpdateAvailable
                            becomes True) — avoids needing a new
                            inverted-bool-to-visibility converter just
                            for this one place.

                            While a check is in flight the button is
                            disabled and the inner TextBlock swaps to
                            "Prüfe..." so the user gets feedback that
                            the click registered. Both states are
                            driven by the same UpdateChecking flag,
                            flipped by UpdateService inside its
                            try/finally guard.

                            Subdued styling (BgSecondary fill rather
                            than AccentBlue) because this is a
                            secondary action — we don't want it
                            competing with the Connect button above
                            for the user's primary attention.
                        -->
                        <Button x:Name="CheckForUpdatesButton"
                                Click="OnCheckForUpdatesClick"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Padding="14,6"
                                Background="{StaticResource BgSecondary}"
                                Foreground="{StaticResource TextPrimary}"
                                FontSize="12"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderMuted}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <!--
                                            Hide entirely when an update
                                            block is showing — the
                                            install button takes over
                                            this slot. Putting the
                                            visibility flip on this
                                            button (rather than wrapping
                                            the install block in an
                                            inverted converter) keeps
                                            the install block's existing
                                            BoolToVis binding untouched.
                                        -->
                                        <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <!--
                                            Disable while a check is
                                            running. The text swap
                                            happens on the inner
                                            TextBlock (see below) —
                                            we can't override Content
                                            from a Style trigger when
                                            it's already a child element
                                            via property-element syntax.
                                        -->
                                        <DataTrigger Binding="{Binding UpdateChecking}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="Opacity" Value="0.7" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BgPrimary}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <!--
                                Use a TextBlock (not Content="...") so
                                Style.Triggers can override the Text
                                property when UpdateChecking flips.
                                Setting Content="..." on the Button
                                attribute would be a local-value win
                                that triggers can't beat.
                            -->
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Auf Updates prüfen" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateChecking}" Value="True">
                                                <Setter Property="Text" Value="Prüfe..." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <!--
                            Token-rotate button (Welle A — option A3).
                            Routine workflow affordance, distinct from
                            the AccentRed "Gerät neu koppeln" button
                            below.

                            Visual contract:
                              - Rotate = AccentBlue, positive action.
                                "I want a fresh token, no fuss."
                              - Re-pair = AccentRed, panic mode.
                                "Something is broken, let me unpair."

                            Click handler in code-behind tears down the
                            session, clears the token, then auto-opens
                            PairingDialog so the user lands in the
                            pairing flow without a second click. No
                            confirmation MessageBox — clicking Rotate IS
                            the intent confirmation.

                            Visibility gated on HasToken=true via
                            BoolToVis converter, same as the re-pair
                            button. Nothing to rotate when not paired.
                        -->
                        <Button x:Name="RotateTokenButton"
                                Click="OnRotateTokenClick"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Padding="14,6"
                                Background="{StaticResource AccentBlue}"
                                Foreground="{StaticResource BgPrimary}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Content="Token rotieren"
                                Visibility="{Binding HasToken, Converter={StaticResource BoolToVis}}"
                                ToolTip="Trennt die laufende Sitzung, verwirft den aktuellen Token und öffnet sofort den Pairing-Dialog. Für routine-rotation (z. B. nach server-side token-refresh) — kein Bestätigungsdialog.">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!--
                            Re-pair button (option #3). Lets the user explicitly
                            unpair this device so they can re-pair against a
                            fresh code from the web UI — useful after a token
                            revoke from the server side, or when handing the
                            install over to a different VAM account on the
                            same Windows user. Without this button the only
                            recovery path is deleting %LOCALAPPDATA%\
                            VamAcarsClient\token.dat by hand, which is hostile.

                            Subdued styling — secondary destructive action,
                            shouldn't compete visually with the Connect button
                            or the update install button. Border + transparent
                            fill + AccentRed text reads as "available but be
                            sure". Hover swaps to a faintly-tinted background
                            for affordance feedback. The actual destructive
                            confirmation lives in the Click handler's
                            MessageBox, defaulting to No.

                            Visibility: only shown when HasToken=true. There's
                            nothing to unpair when not paired, and showing a
                            disabled re-pair button when paired=false would be
                            misleading ("re-pair from what?"). The Visibility
                            binding via BoolToVis collapses the button entirely
                            in the unpaired state — no layout gap.
                        -->
                        <Button x:Name="RepairButton"
                                Click="OnRepairClick"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Padding="14,6"
                                Background="Transparent"
                                Foreground="{StaticResource AccentRed}"
                                FontSize="12"
                                BorderThickness="1"
                                BorderBrush="{StaticResource AccentRed}"
                                Cursor="Hand"
                                Content="Gerät neu koppeln"
                                Visibility="{Binding HasToken, Converter={StaticResource BoolToVis}}"
                                ToolTip="Löscht den gespeicherten ACARS-Token und trennt die laufende Sitzung. Anschließend über die CLI mit einem frischen Pairing-Code neu koppeln.">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.8" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ─── FOOTER ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderMuted}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,4,0,0">
            <TextBlock Text="{Binding StatusMessage, FallbackValue='Bereit.'}"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="11"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
