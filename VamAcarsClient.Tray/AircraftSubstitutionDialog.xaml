<Window x:Class="VamAcarsClient.Tray.AircraftSubstitutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VAM ACARS Client — Flugzeug-Diskrepanz"
        Width="560"
        Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1c1c23"
        Foreground="#e8e8ee"
        FontFamily="Segoe UI">

    <!--
        Aircraft-substitution dialog (Welle B — B4 phase 2C).

        Shown by MainWindow's "Verbinden" click-handler when the
        sim-loaded aircraft type doesn't match the booking's
        aircraft type. Gives the pilot three paths forward:

          1. "Beabsichtigt" — pilot deliberately chose the wrong
             aircraft (livery preference, training, mood). Optional
             reason textbox lets them add free-text context. PIREP
             will show "intentional" + reason.

          2. "Falsche Maschine geladen — Sim schließen" — pilot
             intends to fix the loaded aircraft. Connect-flow
             aborts client-side; no heartbeat is sent; no record
             of the disposition reaches the server (silence is
             the signal). User then loads the right plane in MSFS
             and re-clicks Verbinden.

          3. "Buchung falsch — Admin kontaktieren" — pilot
             believes the booking aircraft is wrong and wants
             admin to reconcile. PIREP filed with the flown
             aircraft and a flag raised for admin review.

        The dialog binds its mismatch summary from code-behind
        via the BookedSummary / FlownSummary fields.

        Confirm button is disabled until a radio is selected; for
        "Beabsichtigt" it stays enabled regardless of reason
        textbox state (reason is optional per the server schema).

        DialogResult semantics:
          - true   = user confirmed (read ChosenIntent / Reason)
          - false  = user clicked Abbrechen
          - null   = user closed the window via X-button
                     (treated as Abbrechen by caller)
    -->
    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1c1c23" />
        <SolidColorBrush x:Key="BgSecondary" Color="#25252e" />
        <SolidColorBrush x:Key="BgTertiary" Color="#2e2e38" />
        <SolidColorBrush x:Key="BorderMuted" Color="#34343f" />
        <SolidColorBrush x:Key="TextPrimary" Color="#e8e8ee" />
        <SolidColorBrush x:Key="TextMuted" Color="#9090a0" />
        <SolidColorBrush x:Key="AccentBlue" Color="#78c8ff" />
        <SolidColorBrush x:Key="AccentYellow" Color="#f5c451" />
        <SolidColorBrush x:Key="AccentRed" Color="#ff7a87" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Banner ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource AccentYellow}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="FLUGZEUG-DISKREPANZ"
                           Foreground="{StaticResource AccentYellow}"
                           FontSize="11"
                           FontWeight="SemiBold" />
                <TextBlock Text="Dein gebuchtes Flugzeug stimmt nicht mit dem in MSFS geladenen überein."
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="13"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ─── Mismatch summary ────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderMuted}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="GEBUCHT"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="BookedSummary"
                               Text="—"
                               Foreground="{StaticResource AccentBlue}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="GELADEN"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="FlownSummary"
                               Text="—"
                               Foreground="{StaticResource AccentYellow}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── Instructions ───────────────────────────────────────── -->
        <TextBlock Grid.Row="2"
                   Margin="0,0,0,8"
                   FontSize="12"
                   Foreground="{StaticResource TextMuted}"
                   TextWrapping="Wrap"
                   Text="Wie möchtest du fortfahren? Diese Auswahl wird auf der PIREP-Seite festgehalten." />

        <!-- ─── Option cards ───────────────────────────────────────── -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Option 1: Intentional -->
                <Border Background="{StaticResource BgSecondary}"
                        BorderBrush="{StaticResource BorderMuted}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <RadioButton x:Name="OptionIntentional"
                                     GroupName="SubstitutionChoice"
                                     Checked="OnOptionChanged"
                                     Foreground="{StaticResource TextPrimary}"
                                     FontSize="13"
                                     FontWeight="SemiBold">
                            <RadioButton.Content>
                                <StackPanel>
                                    <TextBlock Text="Beabsichtigt" />
                                    <TextBlock Text="Ich fliege bewusst dieses Flugzeug (z.B. Livery-Variante, Training)."
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="11"
                                               FontWeight="Normal"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </RadioButton.Content>
                        </RadioButton>
                        <StackPanel x:Name="ReasonPanel"
                                    Visibility="Collapsed"
                                    Margin="22,8,0,0">
                            <TextBlock Text="Grund (optional, max. 200 Zeichen)"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="ReasonTextBox"
                                     MaxLength="200"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"
                                     Background="{StaticResource BgTertiary}"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="{StaticResource BorderMuted}"
                                     BorderThickness="1"
                                     Padding="8,6"
                                     FontSize="12"
                                     MinHeight="60"
                                     CaretBrush="{StaticResource AccentBlue}"
                                     SelectionBrush="{StaticResource AccentBlue}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Option 2: WrongLoaded -->
                <Border Background="{StaticResource BgSecondary}"
                        BorderBrush="{StaticResource BorderMuted}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,8">
                    <RadioButton x:Name="OptionWrongLoaded"
                                 GroupName="SubstitutionChoice"
                                 Checked="OnOptionChanged"
                                 Foreground="{StaticResource TextPrimary}"
                                 FontSize="13"
                                 FontWeight="SemiBold">
                        <RadioButton.Content>
                            <StackPanel>
                                <TextBlock Text="Falsche Maschine geladen — Sim schließen" />
                                <TextBlock Text="Verbinden wird abgebrochen. Lade in MSFS das richtige Flugzeug und versuche es erneut."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11"
                                           FontWeight="Normal"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton.Content>
                    </RadioButton>
                </Border>

                <!-- Option 3: WrongBooking -->
                <Border Background="{StaticResource BgSecondary}"
                        BorderBrush="{StaticResource BorderMuted}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,8">
                    <RadioButton x:Name="OptionWrongBooking"
                                 GroupName="SubstitutionChoice"
                                 Checked="OnOptionChanged"
                                 Foreground="{StaticResource TextPrimary}"
                                 FontSize="13"
                                 FontWeight="SemiBold">
                        <RadioButton.Content>
                            <StackPanel>
                                <TextBlock Text="Buchung falsch — Admin kontaktieren" />
                                <TextBlock Text="PIREP wird mit aktuellem Flugzeug eingereicht und für Admin-Review markiert."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11"
                                           FontWeight="Normal"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton.Content>
                    </RadioButton>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ─── Action row ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">

            <Button x:Name="ConfirmButton"
                    Click="OnConfirmClick"
                    IsEnabled="False"
                    Padding="14,6"
                    Margin="0,0,8,0"
                    Background="{StaticResource AccentBlue}"
                    Foreground="{StaticResource BgPrimary}"
                    FontSize="12"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Content="Bestätigen">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="CancelButton"
                    Click="OnCancelClick"
                    Padding="14,6"
                    Background="Transparent"
                    Foreground="{StaticResource TextMuted}"
                    FontSize="12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderMuted}"
                    Cursor="Hand"
                    Content="Abbrechen"
                    IsCancel="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgPrimary}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
