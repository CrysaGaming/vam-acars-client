<Window x:Class="VamAcarsClient.Tray.PairingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gerät pairen"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1c1c23"
        Foreground="#e8e8ee"
        FontFamily="Segoe UI">

    <!--
        ACARS device pairing dialog (option: in-app pairing).

        Replaces the CLI-only Mode 1 pairing flow for users who never
        interact with the dev console. Same backend protocol — the user
        opens vam.kevindrack.de/settings, generates a one-shot 9-char
        code (XXX-XXX-XXX), pastes it here. We POST to /api/acars/
        pairing/redeem via PairingService, store the returned token via
        DPAPI, and flip State.HasToken so MainWindow's "✓ Gepaart"
        badge updates. The "Pairen…" button on MainWindow's VERBINDUNG
        card opens this; on success we close ourselves with
        DialogResult=true so the caller can refresh.

        Theme matches MainWindow exactly so the dialog feels like a
        sub-surface of the same app rather than a transplant.
    -->
    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1c1c23" />
        <SolidColorBrush x:Key="BgSecondary" Color="#25252e" />
        <SolidColorBrush x:Key="BorderMuted" Color="#34343f" />
        <SolidColorBrush x:Key="TextPrimary" Color="#e8e8ee" />
        <SolidColorBrush x:Key="TextMuted" Color="#9090a0" />
        <SolidColorBrush x:Key="AccentBlue" Color="#78c8ff" />
        <SolidColorBrush x:Key="AccentGreen" Color="#5dd594" />
        <SolidColorBrush x:Key="AccentRed" Color="#ff7a87" />
        <SolidColorBrush x:Key="AccentYellow" Color="#f5c451" />
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Header -->
        <TextBlock Text="Gerät mit VAM pairen"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}" />

        <TextBlock Margin="0,4,0,16"
                   FontSize="11"
                   Foreground="{StaticResource TextMuted}"
                   TextWrapping="Wrap"
                   Text="Verknüpft diesen Computer mit deinem VAM-Account, damit ACARS-Heartbeats deinem Piloten zugeordnet werden." />

        <!--
            Step-by-step instructions. Hyperlink to {ServerUrl}/settings
            opens the system browser via the OnSettingsLinkClick handler
            (RequestNavigate event). Falls auf code-behind weil WPF nicht
            out-of-the-box auf Hyperlink.NavigateUri ein Process.Start
            macht — das muss der host machen.
        -->
        <Border Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderMuted}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Foreground="{StaticResource TextPrimary}"
                           FontSize="12"
                           TextWrapping="Wrap">
                    <Run Text="1. Öffne in deinem Browser:" />
                </TextBlock>
                <TextBlock Margin="0,4,0,0" FontSize="12">
                    <Hyperlink x:Name="SettingsLink"
                               Foreground="{StaticResource AccentBlue}"
                               RequestNavigate="OnSettingsLinkClick">
                        <Run x:Name="SettingsLinkText" Text="{Binding ServerUrl}" />
                    </Hyperlink>
                </TextBlock>

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Text="2. Scrolle zur 'ACARS-Client'-Sektion und klicke 'Pairing-Code generieren'." />

                <TextBlock Margin="0,8,0,0"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Text="3. Trage den 9-stelligen Code unten ein (Format: XXX-XXX-XXX). Der Code ist 15 Minuten gültig." />
            </StackPanel>
        </Border>

        <!-- Code input -->
        <TextBlock Text="Pairing-Code"
                   Foreground="{StaticResource TextMuted}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />
        <TextBox x:Name="CodeBox"
                 Background="{StaticResource BgSecondary}"
                 Foreground="{StaticResource TextPrimary}"
                 BorderBrush="{StaticResource BorderMuted}"
                 BorderThickness="1"
                 Padding="10,8"
                 FontFamily="Consolas"
                 FontSize="16"
                 MaxLength="11"
                 CaretBrush="{StaticResource AccentBlue}"
                 SelectionBrush="{StaticResource AccentBlue}"
                 KeyDown="OnCodeBoxKeyDown"
                 TextChanged="OnCodeChanged" />

        <TextBlock Margin="0,4,0,0"
                   FontSize="11"
                   Foreground="{StaticResource TextMuted}"
                   Text="Beispiel: X4F-7K2-9PB" />

        <!--
            Error/status display. Visibility flipped from code-behind
            depending on outcome:
              - Idle (initial)         → Collapsed
              - Sending …              → Visible, AccentBlue text
              - Server returned error  → Visible, AccentRed text
              - Transport error        → Visible, AccentRed text
            Single TextBlock so layout doesn't jump as the state changes;
            colour comes from a code-behind brush swap (StatusBrush).
        -->
        <TextBlock x:Name="StatusText"
                   Margin="0,12,0,0"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <!-- Buttons -->
        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelButton"
                    Grid.Column="1"
                    Click="OnCancelClick"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Background="{StaticResource BgSecondary}"
                    Foreground="{StaticResource TextPrimary}"
                    FontSize="12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderMuted}"
                    Cursor="Hand"
                    Content="Abbrechen">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!--
                Submit-button. Default action — Enter im CodeBox triggert
                via IsDefault="True" einen Click. Disabled while a request
                is in flight (IsSending state in code-behind toggles
                IsEnabled directly to avoid binding-converter overhead for
                a single dialog).
            -->
            <Button x:Name="SubmitButton"
                    Grid.Column="2"
                    Click="OnSubmitClick"
                    IsDefault="True"
                    Padding="18,8"
                    Background="{StaticResource AccentBlue}"
                    Foreground="{StaticResource BgPrimary}"
                    FontSize="12"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Content="Pairen">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </StackPanel>
</Window>
